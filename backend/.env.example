# Port the API listens on
PORT=4000

# Path to the SAME SQLite file the Python scraper writes to
DB_PATH=../db/news.db

# Absolute path to the Python interpreter to use when triggering the
# ingestion pipeline. Use whatever "python" resolves to on the host,
# or a venv path in production, e.g. /opt/venv/bin/python
PYTHON_BIN=python3

# Absolute or relative path to the scraper folder (contains pipeline.py)
SCRAPER_DIR=../scraper

# Comma separated list of origins allowed to call this API
CORS_ORIGIN=http://localhost:3000
