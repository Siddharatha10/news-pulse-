# Path to the shared SQLite database. Both the scraper and the backend
# point at the same file so the API can read whatever the pipeline writes.
DB_PATH=../db/news.db

# Minimum number of shared keywords for two articles to be considered
# the same topic. See README for how this number was picked.
CLUSTER_OVERLAP_THRESHOLD=3

# How many words to keep in an article's keyword fingerprint.
KEYWORDS_PER_ARTICLE=12
